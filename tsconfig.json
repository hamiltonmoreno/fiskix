{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "supabase/functions/_shared/**/*.ts",
    "supabase/functions/scoring-engine/pure.ts"
  ],
  "exclude": [
    "node_modules",
    "supabase/functions/balanco-energetico",
    "supabase/functions/ingest-data",
    "supabase/functions/ml-scoring",
    "supabase/functions/send-sms",
    "supabase/functions/scoring-engine/index.ts"
  ]
}
